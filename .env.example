# ─── LLM Provider ────────────────────────────────────────────────────────────
# Choose "openai" or "groq"
LLM_PROVIDER=openai

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ─── Groq (optional, faster / cheaper) ───────────────────────────────────────
GROQ_API_KEY=gsk_...
# LLM_MODEL=llama3-70b-8192

# ─── Vector Store ────────────────────────────────────────────────────────────
CHROMA_BASE_DIR=data/sessions

# ─── Retrieval ───────────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K=5
RELEVANCE_THRESHOLD=0.25

# ─── HITL ────────────────────────────────────────────────────────────────────
HITL_CONFIDENCE_THRESHOLD=0.55
